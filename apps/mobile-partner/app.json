{
  "expo": {
    "name": "ServeNow Partner",
    "slug": "servenow-partner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "servenow-partner",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f766e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servenow.partner",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan customer booking QR codes for check-in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f766e"
      },
      "package": "com.servenow.partner",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ServeNow Partner to access your camera to scan booking QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
