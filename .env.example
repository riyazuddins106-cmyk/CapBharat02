# Supabase project credentials (Settings > API in your Supabase dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (Settings > Database > Connection string, URI format)
SUPABASE_DATABASE_URL=

# JWT signing secrets - use long random strings
JWT_SECRET=
JWT_REFRESH_SECRET=

# Backend server port (never exposed directly, proxied by the frontend dev server)
PORT=8000
