{
  "name": "servenow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "find node_modules/.pnpm -name 'esbuild' -path '*/bin/esbuild' -exec chmod +x {} +",
    "dev": "concurrently -n server,web -c blue,magenta \"pnpm --filter @servenow/server dev\" \"pnpm --filter @servenow/customer-web dev\"",
    "dev:admin": "pnpm --filter @servenow/admin-web dev",
    "dev:server": "pnpm --filter @servenow/server dev",
    "dev:web": "pnpm --filter @servenow/customer-web dev",
    "build": "pnpm --filter @servenow/customer-web build && pnpm --filter @servenow/admin-web build && pnpm --filter @servenow/partner-web build && pnpm --filter @servenow/server build",
    "db:push": "pnpm --filter @servenow/server db:push",
    "db:generate": "pnpm --filter @servenow/server db:generate",
    "db:studio": "pnpm --filter @servenow/server db:studio"
  },
  "devDependencies": {
    "concurrently": "9.1.0",
    "playwright-chromium": "^1.61.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "qrcode": "^1.5.4"
  }
}
