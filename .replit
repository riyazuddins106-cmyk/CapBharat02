modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Expo Mobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && pnpm expo start --tunnel"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["node", "server/dist/index.js"]

[userenv]

[userenv.shared]
SUPABASE_URL = "https://ugcbxncpipowxqtsczpy.supabase.co"
