modules = ["nodejs-20", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @servenow/admin-web dev"
waitForPort = 5001

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Customer App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Partner App"

[[workflows.workflow]]
name = "Expo Customer App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && bash ../../scripts/expo-tunnel.sh 8081 --authtoken-var NGROK_AUTHTOKEN --config-home /tmp/ngrok-customer"

[[workflows.workflow]]
name = "Expo Partner App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile-partner && bash ../../scripts/expo-tunnel.sh 8082 --authtoken-var NGROK_AUTHTOKEN_2 --config-home /tmp/ngrok-partner"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["node", "server/dist/index.js"]

[userenv]

[userenv.shared]
SUPABASE_URL = "https://ugcbxncpipowxqtsczpy.supabase.co"
EXPO_PUBLIC_API_URL = "https://a5541275-b8d1-4438-a4d0-f783129b82f1-00-3eh6tge7ul3k4.pike.replit.dev"
