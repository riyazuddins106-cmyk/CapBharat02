modules = ["nodejs-20", "web", "python-base-3.13"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @servenow/admin-web dev"
waitForPort = 5001

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Expo Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && bash ../../scripts/expo-tunnel.sh 8081 --clear"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Partner"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Mobile"

[[workflows.workflow]]
name = "Expo Partner"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile-partner && bash ../../scripts/expo-tunnel.sh 8082 --clear --port 8082"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 5001

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["node", "server/dist/index.js"]

[userenv]

[userenv.shared]
SUPABASE_URL = "https://ugcbxncpipowxqtsczpy.supabase.co"
EXPO_PUBLIC_API_URL = "https://fd52b957-0273-4e0a-88e9-095ee44c96cf-00-24eucvevwr1ic.pike.replit.dev"
