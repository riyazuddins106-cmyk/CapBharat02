modules = ["nodejs-20", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @servenow/admin-web dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Customer App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Partner App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow]]
name = "Expo Customer App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && EXPO_PUBLIC_API_URL=https://$REPLIT_DEV_DOMAIN:8000 ../../scripts/expo-tunnel.sh 8080 --authtoken-var NGROK_AUTHTOKEN"
waitForPort = 8080

[[workflows.workflow]]
name = "Expo Partner App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile-partner && EXPO_PUBLIC_API_URL=https://$REPLIT_DEV_DOMAIN:8000 ../../scripts/expo-tunnel.sh 8099 --authtoken-var NGROK_AUTHTOKEN_2 --start-delay 25"
waitForPort = 8099

[[ports]]
localPort = 3000
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3000

[[ports]]
localPort = 8084
externalPort = 4200

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 8180
externalPort = 5173

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["node", "server/dist/index.js"]

[userenv]

[userenv.shared]
JWT_SECRET = "e8466fcc6f875fe10992ddf0fd84b2313de6e950f745e39ee7115c6247bf69a4"
JWT_REFRESH_SECRET = "d96b75a3407ba94b9862eb32d348ba6f86af55196b2cfe67d94b8d95b4548afc"
