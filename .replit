modules = ["nodejs-20", "bash", "web", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @servenow/admin-web dev"
waitForPort = 5001

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Customer App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Partner App"

[[workflows.workflow]]
name = "Expo Customer App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && bash ../../scripts/expo-tunnel.sh 8081 --authtoken-var NGROK_AUTHTOKEN --config-home /tmp/ngrok-customer"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Expo Partner App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile-partner && bash ../../scripts/expo-tunnel.sh 8082 --authtoken-var NGROK_AUTHTOKEN_2 --config-home /tmp/ngrok-partner --start-delay 25"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["node", "server/dist/index.js"]
