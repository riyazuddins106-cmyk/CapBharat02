modules = ["nodejs-20", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @servenow/admin-web dev"
waitForPort = 5001

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Customer App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Partner App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Partner Web"

[[workflows.workflow]]
name = "Expo Customer App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && EXPO_PUBLIC_API_URL=https://$REPLIT_DEV_DOMAIN ../../scripts/expo-tunnel.sh 8080 --authtoken-var NGROK_AUTHTOKEN"
waitForPort = 8080

[[workflows.workflow]]
name = "Expo Partner App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile-partner && EXPO_PUBLIC_API_URL=https://$REPLIT_DEV_DOMAIN ../../scripts/expo-tunnel.sh 8099 --authtoken-var NGROK_AUTHTOKEN_2 --start-delay 25"
waitForPort = 8099

[[workflows.workflow]]
name = "Partner Web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @servenow/partner-web dev"
waitForPort = 4000

[workflows.workflow.metadata]
outputType = "console"

