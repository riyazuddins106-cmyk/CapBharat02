[[ports]]
localPort = 9123
externalPort = 5000

[[ports]]
localPort = 9124
externalPort = 6800

[deployment]
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["node", "server/dist/index.js"]

